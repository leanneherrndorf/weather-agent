# Required — Anthropic API key
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Required for news article search — Tavily API key
# Get one (free tier: 1,000 searches/month) at https://tavily.com/
TAVILY_API_KEY=your-tavily-api-key-here

# Set to "true" for scheduled runs (set automatically by GitHub Actions)
# Do not set manually — use --test flag for local testing
# SCHEDULED_RUN=true
